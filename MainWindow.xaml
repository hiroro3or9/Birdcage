<ui:FluentWindow x:Class="Birdcage.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:Birdcage"
                 xmlns:tb="http://www.hardcodet.net/taskbar"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Title="Birdcage - 録音アプリ" Height="550" Width="450">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <local:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        
        <Style x:Key="RecordButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                    <Setter Property="Background" Value="#E53935"/> <!-- Red for recording -->
                    <Setter Property="BorderBrush" Value="#E53935"/>
                    <Setter Property="Icon" Value="{ui:SymbolIcon Record24}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsRecording}" Value="False">
                    <Setter Property="Background" Value="#43A047"/> <!-- Green for ready -->
                    <Setter Property="BorderBrush" Value="#43A047"/>
                    <Setter Property="Icon" Value="{ui:SymbolIcon Mic24}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Birdcage Recorder">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="MicSparkle24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- タスクトレイアイコンの設定 -->
        <tb:TaskbarIcon x:Name="MyNotifyIcon"
                        ToolTipText="Birdcage (クリックで表示/非表示)"
                        MenuActivation="RightClick"
                        TrayLeftMouseDown="TaskbarIcon_TrayLeftMouseDown">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{Binding RecordingButtonText}" Command="{Binding ToggleRecordingCommand}" />
                    <MenuItem Header="録音ソース" IsEnabled="{Binding IsRecording, Converter={StaticResource InverseBooleanConverter}}">
                        <MenuItem Header="システム音声" IsCheckable="True" IsChecked="{Binding SelectedRecordSource, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:RecordSource.SystemAudio}}" Command="{Binding SetRecordSourceCommand}" CommandParameter="{x:Static local:RecordSource.SystemAudio}" />
                        <MenuItem Header="マイク" IsCheckable="True" IsChecked="{Binding SelectedRecordSource, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:RecordSource.Microphone}}" Command="{Binding SetRecordSourceCommand}" CommandParameter="{x:Static local:RecordSource.Microphone}" />
                        <MenuItem Header="ミックス" IsCheckable="True" IsChecked="{Binding SelectedRecordSource, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:RecordSource.Mix}}" Command="{Binding SetRecordSourceCommand}" CommandParameter="{x:Static local:RecordSource.Mix}" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="終了" Click="MenuExit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Grid Grid.Row="1" Margin="20,10,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 上部：録音コントローラ (Cardコントロールを使って浮き出た感じに) -->
            <ui:Card Grid.Row="0" Margin="0,0,0,15" Padding="20">
                <StackPanel>
                    <TextBlock Text="録音ソースを選択" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding RecordSources}" 
                              SelectedItem="{Binding SelectedRecordSource}" 
                              Margin="0,0,0,20" Padding="10,6"
                              HorizontalAlignment="Stretch"
                              IsEnabled="{Binding IsRecording, Converter={StaticResource InverseBooleanConverter}}"/>

                    <ui:Button Content="{Binding RecordingButtonText}" 
                            Command="{Binding ToggleRecordingCommand}" 
                            Height="65" 
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource RecordButtonStyle}"/>

                    <TextBlock Text="{Binding RecordingTime, StringFormat=mm\\:ss}" 
                               HorizontalAlignment="Center" 
                               FontSize="42" 
                               FontWeight="Bold"
                               Margin="0,15,0,0"
                               Foreground="#E53935"
                               Visibility="{Binding IsRecording, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </ui:Card>

            <!-- 中部：ファイルリスト -->
            <GroupBox Grid.Row="1" Header="録音済みファイル" Margin="0,0,0,15" Background="Transparent" BorderThickness="0">
                <ui:ListView ItemsSource="{Binding AudioFiles}" 
                             SelectedItem="{Binding SelectedAudioFile}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Margin="0,5,0,0" Padding="0">
                    <ui:ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="MusicNote124" Grid.Column="0" Margin="0,0,15,0" FontSize="24" Foreground="{DynamicResource ControlFillColorDefaultBrush}" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" FontSize="14"/>
                                    <TextBlock Text="{Binding CreationTime, StringFormat=yyyy/MM/dd HH:mm:ss}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>
            </GroupBox>

            <!-- 下部：ファイル操作コントローラ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <ui:Button Grid.Column="0" 
                           Content="{Binding PlaybackButtonText}" 
                           Icon="{ui:SymbolIcon Play24}"
                           Command="{Binding TogglePlaybackCommand}" 
                           HorizontalAlignment="Stretch"
                           Height="40" FontSize="14" Appearance="Primary"/>
                
                <ui:Button Grid.Column="2" 
                           Content="削除" 
                           Icon="{ui:SymbolIcon Delete24}"
                           Command="{Binding DeleteFileCommand}" 
                           HorizontalAlignment="Stretch"
                           Height="40" FontSize="14" Appearance="Danger"/>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
