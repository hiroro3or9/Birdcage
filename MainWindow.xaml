<Window x:Class="Birdcage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Birdcage"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="Birdcage - 録音アプリ" Height="500" Width="400">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <local:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        
        <Style x:Key="RecordButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                    <Setter Property="Background" Value="#E53935"/> <!-- Red for recording -->
                </DataTrigger>
                <DataTrigger Binding="{Binding IsRecording}" Value="False">
                    <Setter Property="Background" Value="#43A047"/> <!-- Green for ready -->
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タスクトレイアイコンの設定 -->
        <tb:TaskbarIcon x:Name="MyNotifyIcon"
                        ToolTipText="Birdcage (クリックで表示/非表示)"
                        MenuActivation="RightClick"
                        TrayLeftMouseDown="TaskbarIcon_TrayLeftMouseDown">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{Binding RecordingButtonText}" Command="{Binding ToggleRecordingCommand}" />
                    <MenuItem Header="録音ソース" IsEnabled="{Binding IsRecording, Converter={StaticResource InverseBooleanConverter}}">
                        <MenuItem Header="システム音声" IsCheckable="True" IsChecked="{Binding SelectedRecordSource, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:RecordSource.SystemAudio}}" Command="{Binding SetRecordSourceCommand}" CommandParameter="{x:Static local:RecordSource.SystemAudio}" />
                        <MenuItem Header="マイク" IsCheckable="True" IsChecked="{Binding SelectedRecordSource, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:RecordSource.Microphone}}" Command="{Binding SetRecordSourceCommand}" CommandParameter="{x:Static local:RecordSource.Microphone}" />
                        <MenuItem Header="ミックス" IsCheckable="True" IsChecked="{Binding SelectedRecordSource, Mode=OneWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static local:RecordSource.Mix}}" Command="{Binding SetRecordSourceCommand}" CommandParameter="{x:Static local:RecordSource.Mix}" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="終了" Click="MenuExit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- 上部：録音コントローラ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="録音ソースを選択:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding RecordSources}" 
                      SelectedItem="{Binding SelectedRecordSource}" 
                      Margin="0,0,0,15" Padding="5"
                      IsEnabled="{Binding IsRecording, Converter={StaticResource InverseBooleanConverter}}"/>

            <Button Content="{Binding RecordingButtonText}" 
                    Command="{Binding ToggleRecordingCommand}" 
                    Height="60" 
                    Style="{StaticResource RecordButtonStyle}"/>

            <TextBlock Text="{Binding RecordingTime, StringFormat=mm\\:ss}" 
                       HorizontalAlignment="Center" 
                       FontSize="36" 
                       FontWeight="Bold"
                       Margin="0,10,0,0"
                       Foreground="#E53935"
                       Visibility="{Binding IsRecording, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>

        <!-- 中部：ファイルリスト -->
        <GroupBox Grid.Row="1" Header="録音済みファイル" Margin="0,0,0,10" Padding="5">
            <ListBox ItemsSource="{Binding AudioFiles}" 
                     SelectedItem="{Binding SelectedAudioFile}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CreationTime, StringFormat=yyyy/MM/dd HH:mm:ss}" FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- 下部：ファイル操作コントローラ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" 
                    Content="{Binding PlaybackButtonText}" 
                    Command="{Binding TogglePlaybackCommand}" 
                    Height="35" FontSize="14"/>
            
            <Button Grid.Column="2" 
                    Content="削除" 
                    Command="{Binding DeleteFileCommand}" 
                    Height="35" FontSize="14"
                    Foreground="Red" BorderBrush="Red"/>
        </Grid>
    </Grid>
</Window>
